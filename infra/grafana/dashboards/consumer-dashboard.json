{
  "uid": "smart-warehouse-consumer",
  "title": "Consumer Service",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP Throughput RPS",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [{"datasource": {"type": "prometheus", "uid": "Prometheus"}, "expr": "sum(rate(http_requests_total{job=\"consumer\"}[1m]))", "legendFormat": "requests/sec"}]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP Error Rate",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [{"datasource": {"type": "prometheus", "uid": "Prometheus"}, "expr": "sum(rate(http_request_errors_total{job=\"consumer\"}[1m])) / clamp_min(sum(rate(http_requests_total{job=\"consumer\"}[1m])), 0.001)", "legendFormat": "error ratio"}]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "HTTP Latency Percentiles",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "Prometheus"}, "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"consumer\"}[1m])))", "legendFormat": "p50"},
        {"datasource": {"type": "prometheus", "uid": "Prometheus"}, "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"consumer\"}[1m])))", "legendFormat": "p95"},
        {"datasource": {"type": "prometheus", "uid": "Prometheus"}, "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"consumer\"}[1m])))", "legendFormat": "p99"}
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Event Processing Duration",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "targets": [{"datasource": {"type": "prometheus", "uid": "Prometheus"}, "expr": "histogram_quantile(0.95, sum by (le) (rate(event_processing_duration_seconds_bucket{job=\"consumer\"}[1m])))", "legendFormat": "event p95"}]
    }
  ]
}
