{
  "uid": "smart-warehouse-infra",
  "title": "Infrastructure",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Kafka Consumer Lag",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [{"datasource": {"type": "prometheus", "uid": "Prometheus"}, "expr": "sum(kafka_consumergroup_lag{consumergroup=\"warehouse-state-consumer\"})", "legendFormat": "lag"}]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Kafka Topic Partitions",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [{"datasource": {"type": "prometheus", "uid": "Prometheus"}, "expr": "sum(kafka_topic_partitions{topic=~\"warehouse-events|warehouse-events-dlq\"}) by (topic)", "legendFormat": "{{topic}}"}]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Cassandra Container CPU",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "targets": [{"datasource": {"type": "prometheus", "uid": "Prometheus"}, "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name=~\".*cassandra.*\"}[1m]))", "legendFormat": "{{name}}"}]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Cassandra Container Memory",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "targets": [{"datasource": {"type": "prometheus", "uid": "Prometheus"}, "expr": "container_memory_working_set_bytes{name=~\".*cassandra.*\"}", "legendFormat": "{{name}}"}],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    }
  ]
}
